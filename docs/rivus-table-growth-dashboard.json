    {
      "id": 2,
      "type": "stat",
      "title": "Data growth rows / 24h",
      "description": "Logical data growth from MySQL CDC insert rows in the last 24 hours.",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
          },
          "editorMode": "code",
          "expr": "sum(increase(rivus_table_cdc_rows_total{sink_type=~\"$sink_type\", source_table=~\"$source_table\", action=\"insert\"}[24h])) or vector(0)",
          "legendFormat": "",
          "range": false,
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
